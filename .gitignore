# .gitignore 파일 생성
New-Item .gitignore -ItemType File

# 내용 추가
@"
# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# tfvars (민감한 정보)
*.tfvars
*.tfvars.json

# Lock file
.terraform.tfstate.lock.info

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc
"@ | Out-File -FilePath .gitignore -Encoding utf8