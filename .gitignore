# .gitignore 파일 생성
New-Item .gitignore -ItemType File

# 내용 추가
@"
# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# tfvars (민감한 정보)
*.tfvars
*.tfvars.json

# Lock file
.terraform.tfstate.lock.info

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc
"@ | Out-File -FilePath .gitignore -Encoding utf8

# KEY, PEM 등 20260525 2350 추가
*.pem
*.key
*.pub
id_rsa
id_rsa.pub
# 프로젝트 관련
.terraform.lock.hcl
# 기타 임시파일
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
